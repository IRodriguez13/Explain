# Opcional: https://direnv.net/ — en este directorio ejecutá:  direnv allow
# Carga el venv si existe y registra completions de bash desde el clone (sin copiar a ~/.local).

if [[ -d .venv/bin ]]; then
  PATH_add .venv/bin
fi

if [[ -n "${BASH_VERSION:-}" && -f "${PWD}/completions/explain.bash" ]]; then
  source "${PWD}/completions/explain.bash"
fi
